# empatIA - Configurações de Ambiente
# Copie este arquivo para .env e configure suas chaves

# ===== AI SERVICE =====
# OpenAI Configuration
OPENAI_API_KEY=sua_chave_openai_aqui
MODEL_NAME=gpt-4o
AI_SERVICE_PORT=8001

# ===== AVATAR SERVICE =====
# DID AI Configuration
DID_API_USERNAME=seu_username_aqui
DID_API_PASSWORD=sua_senha_aqui
AVATAR_SERVICE_PORT=8002

# ===== EMOTION SERVICE =====
# OpenFace Configuration
OPENFACE_MODEL_PATH=/models/openface
EMOTION_CONFIDENCE_THRESHOLD=0.7
EMOTION_SERVICE_PORT=8003

# ===== GATEWAY SERVICE =====
# Gateway Configuration
GATEWAY_PORT=8000
LOG_LEVEL=INFO

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:7860,http://localhost:3000

# ===== WEB UI =====
# Frontend Configuration
WEB_UI_PORT=7860
BACKEND_URL=http://gateway-service:8000

# ===== DATABASE =====
# PostgreSQL Configuration (quando implementado)
POSTGRES_DB=empatia
POSTGRES_USER=empatia_user
POSTGRES_PASSWORD=strong_password_here
DATABASE_URL=postgresql://empatia_user:strong_password_here@db:5432/empatia

# ===== REDIS =====
# Cache Configuration (quando implementado)
REDIS_URL=redis://redis:6379/0
REDIS_PASSWORD=redis_password_here

# ===== MONITORING =====
# Prometheus
PROMETHEUS_PORT=9090

# Grafana
GRAFANA_PORT=3000
GRAFANA_ADMIN_PASSWORD=admin_password_here

# Jaeger
JAEGER_PORT=16686

# ===== SECURITY =====
# JWT Configuration (quando implementado)
SECRET_KEY=your_super_secret_key_here_min_32_chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# API Rate Limiting
RATE_LIMIT_PER_MINUTE=60

# ===== DEVELOPMENT =====
# Debug Mode
DEBUG=true

# Hot Reload
HOT_RELOAD=true

# ===== PRODUCTION =====
# Quando em produção, altere estas configurações:
# DEBUG=false
# HOT_RELOAD=false
# LOG_LEVEL=WARNING

# SSL Configuration (produção)
# SSL_CERT_PATH=/certs/cert.pem
# SSL_KEY_PATH=/certs/key.pem

# ===== EXTERNAL SERVICES =====
# Webhook URLs (futuro)
# WEBHOOK_EMOTION_ANALYSIS=https://your-webhook.com/emotion
# WEBHOOK_CONVERSATION_END=https://your-webhook.com/conversation

# Email Configuration (futuro)
# SMTP_SERVER=smtp.gmail.com
# SMTP_PORT=587
# EMAIL_USERNAME=your_email@gmail.com
# EMAIL_PASSWORD=your_app_password

# ===== OBSERVABILITY =====
# Sentry (Error tracking)
# SENTRY_DSN=https://your-sentry-dsn-here

# DataDog (APM)
# DD_API_KEY=your_datadog_api_key
# DD_APP_KEY=your_datadog_app_key

# ===== BACKUP =====
# S3 Configuration for backups
# AWS_ACCESS_KEY_ID=your_aws_access_key
# AWS_SECRET_ACCESS_KEY=your_aws_secret_key
# S3_BUCKET_NAME=empatia-backups
# AWS_REGION=us-east-1 