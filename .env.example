# empatIA - Configurações de Ambiente
# Copie este arquivo para .env e configure suas chaves

# ===== GCP SERVICE =====
CREDENTIALS_JSON=

# ===== AI SERVICE =====
# OpenAI Configuration
OPENAI_API_KEY=
MODEL_NAME=gpt-4o
AI_SERVICE_PORT=8001
TEMPERATURE=0.3
MAX_TOKENS=700

# Local LLM Configuration (AI Service)
# Set ENABLE_LOCAL_LLM=true before building ai-service to download the GGUF model into the image.
# Gemma repositories may require accepting the license on Hugging Face and setting HF_TOKEN.
LLM_PROVIDER=local
LLM_FALLBACK_PROVIDER=openai
ENABLE_LOCAL_LLM=true
LOCAL_MODEL_DOWNLOAD_REQUIRED=false
HF_TOKEN=
# Accepted aliases for local development if you already use one of these names.
HUGGING_FACE_TOKEN=
HUGGIN_FACE_TOKEN=
LOCAL_MODEL_REPO_ID=ggml-org/gemma-4-E4B-it-GGUF
LOCAL_MODEL_INCLUDE=gemma-4-E4B-it-Q4_K_M.gguf
LOCAL_MODEL_DIR=/models/local-llm
# Optional host path mounted by docker-compose.dev.yml. If a matching GGUF is found
# here, ai-service copies it before trying the Hugging Face download.
LOCAL_MODEL_SOURCE_DIR=/home/toni/.lmstudio/models
LOCAL_MODEL_IMPORT_DIR=/host-lmstudio-models
LOCAL_MODEL_IMPORT_PATTERN=gemma-4-E4B-it-Q4_K_M.gguf
LOCAL_LLM_MODEL=gemma4:e4b
LOCAL_LLM_MODEL_PATH=
LOCAL_LLM_CHAT_FORMAT=
LOCAL_LLM_N_CTX=8192
LOCAL_LLM_N_GPU_LAYERS=-1
LOCAL_LLM_N_THREADS=8
LOCAL_LLM_VERBOSE=false
AI_SERVICE_GPUS=all
NVIDIA_VISIBLE_DEVICES=all
NVIDIA_DRIVER_CAPABILITIES=compute,utility
AI_SERVICE_BASE_IMAGE=nvidia/cuda:12.4.1-devel-ubuntu22.04
LLAMA_CPP_CUDA=true
LLAMA_CPP_VERSION=0.3.7
LLAMA_CPP_CMAKE_ARGS="-DGGML_CUDA=on -DCMAKE_CUDA_ARCHITECTURES=86 -DLLAMA_BUILD_EXAMPLES=OFF -DLLAMA_BUILD_TESTS=OFF -DLLAMA_BUILD_SERVER=OFF"
CMAKE_BUILD_PARALLEL_LEVEL=2
LLAMA_CPP_PIP_EXTRA_ARGS=

# ===== AVATAR SERVICE =====
# DID AI Configuration
DID_API_USERNAME=seu_username_aqui
DID_API_PASSWORD=sua_senha_aqui
AVATAR_SERVICE_PORT=8002

# ===== EMOTION SERVICE =====
# OpenFace Configuration
OPENFACE_MODEL_PATH=/models/openface
EMOTION_CONFIDENCE_THRESHOLD=0.7
EMOTION_SERVICE_PORT=8003

# ===== GATEWAY SERVICE =====
# Gateway Configuration
GATEWAY_PORT=8000
LOG_LEVEL=INFO

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:7860,http://localhost:3000

# ===== WEB UI =====
# Frontend Configuration
WEB_UI_PORT=7860
BACKEND_URL=http://gateway-service:8000

# ===== DATABASE =====
# PostgreSQL Configuration (quando implementado)
POSTGRES_DB=empatia
POSTGRES_USER=empatia_user
POSTGRES_PASSWORD=strong_password_here
DATABASE_URL=postgresql://empatia_user:strong_password_here@db:5432/empatia

# ===== REDIS =====
# Cache Configuration (quando implementado)
REDIS_URL=redis://redis:6379/0
REDIS_PASSWORD=redis_password_here

# ===== MONITORING =====
# Prometheus
PROMETHEUS_PORT=9090

# Grafana
GRAFANA_PORT=3000
GRAFANA_ADMIN_PASSWORD=admin_password_here

# Jaeger
JAEGER_PORT=16686

# ===== SECURITY =====
# JWT Configuration (quando implementado)
SECRET_KEY=your_super_secret_key_here_min_32_chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# API Rate Limiting
RATE_LIMIT_PER_MINUTE=60

# ===== DEVELOPMENT =====
# Debug Mode
DEBUG=true

# Hot Reload
HOT_RELOAD=true

# ===== PRODUCTION =====
# Quando em produção, altere estas configurações:
# DEBUG=false
# HOT_RELOAD=false
# LOG_LEVEL=WARNING

# SSL Configuration (produção)
# SSL_CERT_PATH=/certs/cert.pem
# SSL_KEY_PATH=/certs/key.pem

# ===== EXTERNAL SERVICES =====
# Webhook URLs (futuro)
# WEBHOOK_EMOTION_ANALYSIS=https://your-webhook.com/emotion
# WEBHOOK_CONVERSATION_END=https://your-webhook.com/conversation

# Email Configuration (futuro)
# SMTP_SERVER=smtp.gmail.com
# SMTP_PORT=587
# EMAIL_USERNAME=your_email@gmail.com
# EMAIL_PASSWORD=your_app_password

# ===== OBSERVABILITY =====
# Sentry (Error tracking)
# SENTRY_DSN=https://your-sentry-dsn-here

# DataDog (APM)
# DD_API_KEY=your_datadog_api_key
# DD_APP_KEY=your_datadog_app_key

# ===== BACKUP =====
# S3 Configuration for backups
# AWS_ACCESS_KEY_ID=your_aws_access_key
# AWS_SECRET_ACCESS_KEY=your_aws_secret_key
# S3_BUCKET_NAME=empatia-backups
# AWS_REGION=us-east-1 
